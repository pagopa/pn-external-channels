    "@types/node": "^22.5.0",
    "esbuild": "0.25.0",
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
    "sonarqube-scanner": "^3.5.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.2.0"
  },
